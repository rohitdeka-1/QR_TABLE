<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Your OTP Code</title>
</head>
<body style="margin:0;padding:0;background:#f9f8f6;font-family:'Segoe UI',Arial,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background:#f9f8f6;padding:40px 16px;">
    <tr>
      <td align="center">
        <table width="520" cellpadding="0" cellspacing="0" style="background:#ffffff;border-radius:16px;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,0.08);">
          <!-- Header -->
          <tr>
            <td style="background:#2a2626;padding:28px 36px;">
              <table cellpadding="0" cellspacing="0">
                <tr>
                  <td style="background:#c84b31;width:36px;height:36px;border-radius:8px;text-align:center;vertical-align:middle;">
                    <span style="color:#fff;font-size:18px;font-weight:bold;">Q</span>
                  </td>
                  <td style="padding-left:12px;color:#fff;font-size:20px;font-weight:600;">
                    QR Restaurant
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding:36px 36px 24px;">
              <p style="margin:0 0 8px;font-size:13px;text-transform:uppercase;letter-spacing:0.15em;color:#c84b31;font-weight:600;">
                {{purposeLabel}}
              </p>
              <h1 style="margin:0 0 16px;font-size:26px;color:#2a2626;font-weight:700;line-height:1.3;">
                Your verification code
              </h1>
              <p style="margin:0 0 28px;font-size:15px;color:#5c5656;line-height:1.6;">
                Hi {{name}}, use the code below to {{actionText}}. It expires in <strong>10 minutes</strong>.
              </p>

              <!-- OTP Box -->
              <div style="background:#f9f8f6;border:2px dashed #c84b31;border-radius:12px;padding:24px;text-align:center;margin-bottom:28px;">
                <span style="font-size:42px;font-weight:800;letter-spacing:14px;color:#2a2626;font-family:'Courier New',monospace;">
                  {{otp}}
                </span>
              </div>

              <p style="margin:0;font-size:13px;color:#5c5656;line-height:1.6;">
                If you didn't request this code, you can safely ignore this email. Your account won't be affected.
              </p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background:#f9f8f6;padding:20px 36px;border-top:1px solid #eae6df;">
              <p style="margin:0;font-size:12px;color:#9a9a9a;text-align:center;">
                &copy; {{year}} QR Restaurant System · This is an automated message, please do not reply.
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
